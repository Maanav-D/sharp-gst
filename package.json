{
  "name": "sharp-gst",
  "version": "1.0.0",
  "description": "Sharp Computers GST - Local GST Accounting Software",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "seed": "node server/seed.js",
    "build": "cd client && npm install && npm run build",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.4.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.13.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
